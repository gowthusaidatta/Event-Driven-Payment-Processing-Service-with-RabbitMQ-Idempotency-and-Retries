#   but suggest keeping it in .gitignore anyway for local customization
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used in a top-level app, Pipfile.lock should be committed,
#   but in a library, it should be ignored.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be either committed or ignored.
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be either committed or ignored.
#   https://pdm.fming.dev/#commit-your-pdmlock-file-to-version-control
# pdm.lock

